---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Portafolio de Marcos Ochoa, desarrollador full-stack enfocado en sistemas web y automatización.",
  image = "/og-image.png",
} = Astro.props;

const NAV_ITEMS = [
  { href: "#proyectos", content: "Proyectos" },
  { href: "#sobre-mi", content: "Sobre mi" },
  { href: "#skills", content: "Skills" },
];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta
      name="theme-color"
      content="#f9fafb"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#09090b"
      media="(prefers-color-scheme: dark)"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      })();

      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>

  <body
    class="antialiased m-0 leading-relaxed min-h-screen font-sans selection:bg-accent/30 selection:text-main"
  >
    <nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50">
      <div
        class="flex items-center p-1.5 bg-surface/80 backdrop-blur-xl border border-divider shadow-lg rounded-full transition-colors duration-300"
      >
        <ul
          class="flex items-center gap-1 px-2 list-none m-0 p-0 text-center"
          id="nav-list"
        >
          <span
            class="bg-bg/35 border border-divider shadow-sm pointer-events-none"
            id="hover-indicator"></span>
          <span
            class="bg-bg/35 border border-divider shadow-sm pointer-events-none"
            id="indicator"></span>
          {
            NAV_ITEMS.map((item) => (
              <li class="flex items-center">
                <a
                  href={item.href}
                  class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors duration-200 text-nowrap"
                >
                  {item.content}
                </a>
              </li>
            ))
          }

          <li>
            <div class="flex items-center">
              <span class="w-px h-5 bg-divider mx-2 pointer-events-none"></span>
              <button
                id="theme-btn"
                type="button"
                aria-label="Cambiar tema"
                class="p-2 rounded-full hover:bg-bg transition-colors text-muted hover:text-main"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                  <line x1="8" y1="21" x2="16" y2="21"></line>
                  <line x1="12" y1="17" x2="12" y2="21"></line>
                </svg>
              </button>
            </div>
          </li>
        </ul>
      </div>
    </nav>

    <slot />
    <script>
      const themeBtn = document.getElementById("theme-btn");
      themeBtn?.addEventListener("click", () => {
        const el = document.documentElement;
        const isDark = el.classList.toggle("dark");

        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    </script>
    <script>
      const nav = document.querySelector("nav");
      const navLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>("#nav-list a"),
      );
      const sections = navLinks
        .map((a) => document.querySelector(a.getAttribute("href") ?? ""))
        .filter((el): el is HTMLElement => el !== null);

      const clearActive = () =>
        navLinks.forEach((a) => a.classList.remove("active"));

      const setActive = (id: string) => {
        clearActive();
        navLinks
          .find((a) => a.getAttribute("href") === `#${id}`)
          ?.classList.add("active");
      };

      // Flag para ignorar el observer mientras el scroll fue disparado por click
      let isManualNav = false;
      let manualNavTimeout: ReturnType<typeof setTimeout>;

      const observer = new IntersectionObserver(
        (entries) => {
          if (isManualNav) return; // ignora el observer durante el scroll por click
          entries.forEach((entry) => {
            if (entry.isIntersecting) setActive(entry.target.id);
          });
        },
        { rootMargin: "-45% 0px -45% 0px", threshold: 0 },
      );
      sections.forEach((section) => observer.observe(section));

      // Click en los links: activa de inmediato y bloquea el observer hasta que termine el scroll
      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          const id = link.getAttribute("href")?.replace("#", "");
          if (!id) return;

          isManualNav = true;
          setActive(id);

          clearTimeout(manualNavTimeout);

          const onScrollEnd = () => {
            isManualNav = false;
            window.removeEventListener("scrollend", onScrollEnd);
          };

          if ("onscrollend" in window) {
            window.addEventListener("scrollend", onScrollEnd);
          } else {
            // Fallback para navegadores sin soporte de scrollend (ej. Safari viejo)
            manualNavTimeout = setTimeout(() => {
              isManualNav = false;
            }, 1000);
          }
        });
      });

      // Estado "arriba" + deselección antes de la primera sección
      const firstSection = document.getElementById("proyectos");
      const lastSection = sections[sections.length - 1];

      const handleTopState = () => {
        if (isManualNav) return;

        const atTop = window.scrollY <= 0;
        nav?.classList.toggle("at-top", atTop);

        const beforeFirstSection =
          firstSection != null &&
          window.scrollY < firstSection.offsetTop - window.innerHeight * 0.45;

        if (atTop || beforeFirstSection) clearActive();

        const scrolledToBottom =
          window.innerHeight + window.scrollY >=
          document.documentElement.scrollHeight - 2;

        if (scrolledToBottom && lastSection) setActive(lastSection.id);
      };

      handleTopState();
      window.addEventListener("scroll", handleTopState, { passive: true });
    </script>
  </body>
</html>

<style>
  #nav-list {
    anchor-name: --active, --hover;

    & a:is(:not(.active)):hover {
      anchor-name: --hover;
      color: var(--color-accent);
      transition: color 400ms ease;
    }

    & a.active {
      anchor-name: --active;
      transition: color 300ms ease;
      color: var(--color-accent);
    }
  }

  #indicator {
    transition:
      left 500ms ease,
      top 500ms ease,
      width 500ms ease,
      height 500ms ease;

    position: absolute;
    position-anchor: --active;
    left: calc(anchor(left) - 4px);
    top: calc(anchor(top) - 4px);

    width: calc(anchor-size(width) + 8px);
    height: calc(anchor-size(height) + 8px);

    border-radius: 999px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.18),
      rgba(255, 255, 255, 0.05)
    );

    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    padding: 4px;
  }

  #hover-indicator {
    transition:
      left 400ms ease,
      top 400ms ease,
      width 400ms ease,
      height 400ms ease,
      opacity 200ms ease;

    position: absolute;
    position-anchor: --hover;
    left: calc(anchor(left) - 4px);
    top: calc(anchor(top) - 4px);

    width: calc(anchor-size(width) + 8px);
    height: calc(anchor-size(height) + 8px);

    border-radius: 999px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.18),
      rgba(255, 255, 255, 0.05)
    );
    border: 1px solid rgba(255, 255, 255, 0.048);
    opacity: 0;
  }

  #nav-list:has(a:not(.active):hover) #hover-indicator {
    opacity: 1;
  }
</style>
