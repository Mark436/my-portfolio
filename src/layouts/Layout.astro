---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body
    class="antialiased m-0 leading-relaxed min-h-screen selection:bg-[var(--accent)]/30 selection:text-[var(--text-main)]"
  >
    <!-- ---------- NAV GLOBAL (Island Style puro) ---------- -->
    <nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50">
      <div
        class="flex items-center p-1.5 bg-[var(--surface)]/80 backdrop-blur-xl border border-[var(--border)] shadow-lg rounded-full transition-colors duration-300"
      >
        <div class="flex items-center gap-1 px-2 font-sans">
          <a
            href="#proyectos"
            class="px-4 py-1.5 rounded-full text-sm font-medium bg-[var(--bg)] text-[var(--accent)] border border-[var(--border)] shadow-sm transition-colors duration-200"
          >
            Proyectos
          </a>
          <a
            href="#sobre-mi"
            class="px-4 py-1.5 rounded-full text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors duration-200"
          >
            Sobre mí
          </a>
          <a
            href="#skills"
            class="px-4 py-1.5 rounded-full text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors duration-200"
          >
            Skills
          </a>
        </div>

        <span class="w-px h-5 bg-[var(--border)] mx-2"></span>

        <!-- Theme Toggler -->
        <button
          id="theme-btn"
          aria-label="Cambiar tema"
          class="p-2 rounded-full hover:bg-[var(--bg)] transition-colors text-[var(--text-muted)] hover:text-[var(--text-main)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
        </button>
      </div>
    </nav>

    <slot />

    <!-- Lógica del botón de tema ahora vive en el layout -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const themeBtn = document.getElementById("theme-btn");
        const handleToggleClick = () => {
          const element = document.documentElement;
          element.classList.toggle("dark");
          const isDark = element.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
        };

        if (themeBtn) {
          themeBtn.addEventListener("click", handleToggleClick);
        }
      });
    </script>
  </body>
</html>
