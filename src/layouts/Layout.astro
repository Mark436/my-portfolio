---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Portafolio de Marcos Ochoa, desarrollador full-stack enfocado en sistemas web y automatización.",
  image = "/og-image.png",
} = Astro.props;

const NAV_ITEMS = [
  { href: "#proyectos", content: "Proyectos" },
  { href: "#sobre-mi", content: "Sobre mi" },
  { href: "#skills", content: "Skills" },
];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta
      name="theme-color"
      content="#f9fafb"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#09090b"
      media="(prefers-color-scheme: dark)"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      })();

      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>

  <body
    class="antialiased m-0 leading-relaxed min-h-screen font-sans selection:bg-accent/30 selection:text-main"
  >
    <nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50">
      <div
        class="flex items-center p-1.5 bg-surface/80 backdrop-blur-xl border border-divider shadow-lg rounded-full transition-colors duration-300"
      >
        <ul class="flex items-center gap-1 px-2 list-none m-0 p-0">
          {
            NAV_ITEMS.map((item) => (
              <li>
                <a
                  href={item.href}
                  /*bg-bg text-accent border border-divider shadow-sm estilos activo*/
                  class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors duration-200"
                >
                  {item.content}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="#proyectos"
              class="px-4 py-1.5 rounded-full text-sm font-medium bg-bg text-accent border border-divider shadow-sm transition-colors duration-200"
            >
              Proyectos
            </a>
          </li>
          <li>
            <a
              href="#sobre-mi"
              class="px-4 py-1.5 rounded-full text-sm font-medium text-muted hover:text-main transition-colors duration-200 text-nowrap"
            >
              Sobre mí
            </a>
          </li>
          <li>
            <a
              href="#skills"
              class="px-4 py-1.5 rounded-full text-sm font-medium text-muted hover:text-main transition-colors duration-200"
            >
              Skills
            </a>
          </li>
          <li>
            <div class="flex items-center">
              <span class="w-px h-5 bg-divider mx-2"></span>
              <button
                id="theme-btn"
                type="button"
                aria-label="Cambiar tema"
                class="p-2 rounded-full hover:bg-bg transition-colors text-muted hover:text-main"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                  <line x1="8" y1="21" x2="16" y2="21"></line>
                  <line x1="12" y1="17" x2="12" y2="21"></line>
                </svg>
              </button>
            </div>
          </li>
        </ul>
      </div>
    </nav>

    <slot />
  </body>
</html>

<script>
  document.addEventListener("astro:page-load", () => {
    const themeBtn = document.getElementById("theme-btn");
    themeBtn?.addEventListener("click", () => {
      const el = document.documentElement;
      const isDark = el.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  });
</script>
