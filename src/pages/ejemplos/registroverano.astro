---
import Layout from "@/layouts/Layout.astro";
Layout;
---

<style>
  .back-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;

    padding: 0.85rem 1.4rem;
    border: 1px solid var(--border-divider);
    border-radius: 14px;

    background: #111827;
    color: #f9fafb;

    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;

    cursor: pointer;
    user-select: none;

    box-shadow: 0 2px 8px rgb(0 0 0 / 8%);
    transition:
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .back-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgb(0 0 0 / 12%);
  }

  .back-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgb(0 0 0 / 8%);
  }

  .back-btn:focus-visible {
    outline: none;
    border-color: #60a5fa;
    box-shadow: 0 0 0 4px rgb(96 165 250 / 20%);
  }
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Segoe UI", sans-serif;
  }

  body {
    background: #f4f5fb;
    padding: 16px 20px;
    color: #2b2b45;
  }

  .wrapper {
    max-width: 1000px;
    margin: auto;
    background: #fff;
    border-radius: 22px;
    padding: 35px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    border: 1px solid #ececf5;

    position: relative;
  }
  .settings-btn {
    content: "";
    position: absolute;
    top: 1em;
    right: 1em;

    font-size: 1.5em;
    padding: 0;
    margin: 0;
    width: fit-content;
    height: fit-content;
    opacity: 0.5;

    background-color: #4b4b63;
    border-radius: 0.4em;
  }

  .header {
    margin-bottom: 35px;
  }

  .accent-bar {
    width: 70px;
    height: 6px;
    border-radius: 20px;
    background: linear-gradient(90deg, #6c63ff, #8f88ff);
    margin-bottom: 18px;
  }

  .header h1 {
    font-size: 32px;
    color: #2f2a55;
    font-weight: 700;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }

  .section-label {
    grid-column: 1/-1;
    font-size: 18px;
    font-weight: 700;
    color: #5b54a4;
    margin-top: 10px;
  }

  .divider {
    grid-column: 1/-1;
    height: 1px;
    background: #ececf5;
    margin: 5px 0;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .field.full {
    grid-column: 1/-1;
  }

  label,
  span {
    font-size: 14px;
    font-weight: 600;
    color: #4b4b63;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid #d9dbe8;
    background: #fafafe;
    border-radius: 12px;
    padding: 14px 16px;
    font-size: 15px;
    transition:
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
    outline: none;
    color: #2d2d44;
  }

  textarea {
    min-height: 120px;
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: #6c63ff;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.12);
  }

  ::placeholder {
    color: #a2a4b8;
  }

  .color-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .color-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid #ddd;
    flex-shrink: 0;
  }

  .actions {
    display: flex;
    gap: 14px;
    margin-top: 35px;
  }

  button {
    border: none;
    cursor: pointer;
    transition: box-shadow 0.25s ease transform.25s ease;
    font-size: 15px;
    font-weight: 600;
    border-radius: 12px;
    padding: 14px 24px;
  }

  .btn-primary {
    background: linear-gradient(90deg, #6c63ff, #7f77ff);
    color: white;
    box-shadow: 0 8px 18px rgba(108, 99, 255, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 22px rgba(108, 99, 255, 0.32);
  }

  .btn-secondary {
    background: #eef0f7;
    color: #555a78;
  }

  .btn-secondary:hover {
    background: #e2e6f2;
  }

  .toast {
    position: fixed;
    bottom: 30px;
    right: 30px;
    background: #2f2a55;
    color: #fff;
    padding: 14px 20px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.18);
  }

  .toast.show {
    opacity: 1;
    transform: translateY(0);
  }

  .login-overlay {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: rgba(0, 0, 0, 0.25);
    width: 100%;
    height: 100%;
    backdrop-filter: blur(10px);
    z-index: 2;
  }
  .login-card {
    background: #fff;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);

    display: flex;
    flex-direction: column;
    align-items: center;

    gap: 1em;

    padding: 2em 2em;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    text-align: center;
  }
  #googleBtn {
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 8px 18px rgba(66, 133, 244, 0.25);
    transition:
      box-shadow 0.3s ease,
      scale 0.3s ease;
  }

  #googleBtn:hover {
    box-shadow: 0 12px 22px rgba(66, 133, 244, 0.32);
    scale: 1.02;
    transition:
      box-shadow 0.3s ease,
      scale 0.3s ease;
  }

  @media (max-width: 768px) {
    body {
      padding: 0;
    }
    .wrapper {
      padding: 25px;
      border-radius: 15px;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .header h1 {
      font-size: 26px;
    }

    .actions {
      flex-direction: column;
    }

    button {
      width: 100%;
    }
  }
</style>

