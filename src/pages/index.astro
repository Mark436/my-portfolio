---
import Layout from '../layouts/Layout.astro';

// Tu información original, adaptada para pedir una imagen 
const PROYECTOS = [
  {
    id: 'v3',
    tag: '2026 · v3',
    title: 'PublicacionesITH',
    desc: 'CMS para el departamento de comunicación de ITH: publicaciones, dashboard de noticias, administración de usuarios y panel de estadísticas, con sistema de diseño propio.',
    image: 'https://placehold.co/600x340/111827/e5e7eb?text=Publicaciones+ITH', // Cambia esto por la ruta de tu captura
    chips: ['HTML/CSS', 'Sistema de diseño', 'Equipo'],
    github: 'https://github.com/marcos/pub-ith',
    preview: 'https://pub-ith.example.com'
  },
  {
    id: 'v2',
    tag: '2026 · v2',
    title: 'Registro de Veranos',
    desc: 'Sistema de registro estudiantil con Google Apps Script sobre Google Sheets como base de datos, autenticación con Google OAuth y escritura en cola para respuestas más rápidas.',
    image: 'https://placehold.co/600x340/111827/e5e7eb?text=Registro+Veranos',
    chips: ['Google Apps Script', 'OAuth', 'Netlify'],
    github: null, 
    preview: 'https://veranos.example.com'
  },
  {
    id: 'v1',
    tag: '2025 · v1',
    title: 'Pipeline de edición de video',
    desc: 'Herramienta en Python que elimina silencios de un video automáticamente, genera subtítulos y sincroniza audio externo por correlación cruzada.',
    image: 'https://placehold.co/600x340/111827/e5e7eb?text=Video+Pipeline',
    chips: ['Python', 'FFmpeg', 'Whisper'],
    github: 'https://github.com/marcos/video-pipeline',
    preview: null 
  }
];
---

<Layout title="Marcos Ochoa — Portfolio">
  <main class="pt-28 md:pt-36">
    
    <!-- ---------- HERO ---------- -->
    <section class="pb-24 border-b border-[var(--border)] transition-colors duration-300">
      <div class="max-w-4xl mx-auto px-8">
        
        <!-- Foto de perfil y tag -->
        <div class="mb-8">
          <img 
            src="https://placehold.co/120x120/111827/e5e7eb?text=MO" 
            alt="Marcos Ochoa" 
            class="w-24 h-24 md:w-28 md:h-28 rounded-full border-4 border-[var(--surface)] shadow-md object-cover transition-colors duration-300"
          />
        </div>

        <div class="flex items-center gap-2 font-mono text-xs text-[var(--text-muted)] uppercase tracking-widest mb-6">
          <span class="w-2 h-2 rounded-full bg-[var(--accent)] ring-4 ring-[var(--accent)]/20"></span>
          Disponible para proyectos
        </div>
        
        <h1 class="font-mono font-bold text-5xl md:text-7xl leading-none tracking-tight m-0 mb-6 text-[var(--text-main)]">
          Marcos Ochoa
        </h1>
        
        <p class="text-lg md:text-xl text-[var(--text-muted)] max-w-2xl m-0 mb-10 leading-relaxed font-sans">
          Desarrollador <strong class="text-[var(--text-main)] font-semibold">full-stack</strong> enfocado en sistemas web y automatización. Construyo desde interfaces en React hasta pipelines de backend y scripts que le quitan trabajo repetitivo a la gente.
        </p>
        
        <div class="flex flex-wrap items-center gap-4">
          <!-- Botón Primary -->
          <a href="#proyectos" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-sans text-sm font-medium transition-all duration-200 border shadow-sm hover:shadow-md hover:-translate-y-0.5 active:translate-y-0 active:shadow-sm bg-[var(--primary)] text-[var(--primary-fg)] border-[var(--primary)] hover:opacity-90">
            Ver proyectos
          </a>
          <!-- Botón Secondary -->
          <a href="mailto:marcos@example.com" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-sans text-sm font-medium transition-all duration-200 border shadow-sm hover:shadow-md hover:-translate-y-0.5 active:translate-y-0 active:shadow-sm bg-[var(--surface)] text-[var(--text-main)] border-[var(--border)] hover:bg-[var(--bg)]">
            Contactar por correo
          </a>

          <span class="hidden sm:inline w-px h-8 bg-[var(--border)] mx-2"></span>

          <!-- Íconos -->
          <div class="flex gap-3">
            <a href="https://github.com/marcos" target="_blank" aria-label="GitHub" class="inline-flex items-center justify-center p-2.5 rounded-xl bg-[var(--surface)] border border-[var(--border)] text-[var(--text-muted)] transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 hover:text-[var(--text-main)] active:translate-y-0 active:shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A4.8 4.8 0 0 0 8 18v4"></path></svg>
            </a>
            <!-- <a href="https://linkedin.com/in/marcos" target="_blank" aria-label="LinkedIn" class="inline-flex items-center justify-center p-2.5 rounded-xl bg-[var(--surface)] border border-[var(--border)] text-[var(--text-muted)] transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 hover:text-[var(--text-main)] active:translate-y-0 active:shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a> -->
          </div>
        </div>
      </div>
    </section>

    <!-- ---------- PROYECTOS ---------- -->
    <section id="proyectos" class="max-w-5xl mx-auto px-8 pt-24 pb-12 scroll-mt-24">
      <div class="flex items-center gap-3 mb-16">
        <svg class="text-[var(--text-main)]" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        <h2 class="font-mono text-2xl font-bold m-0 text-[var(--text-main)] tracking-tight">Proyectos</h2>
      </div>

      <div class="flex flex-col gap-16 md:gap-24">
        {PROYECTOS.map((proyecto) => (
          <article class="flex flex-col md:flex-row gap-8 lg:gap-12 fade-up-entry">
            
            <!-- Imagen del proyecto -->
            <div class="w-full md:w-5/12 lg:w-1/2 rounded-2xl overflow-hidden border border-[var(--border)] shadow-sm bg-[var(--surface)]">
              <img 
                src={proyecto.image} 
                alt={`Captura del proyecto ${proyecto.title}`} 
                class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>

            <!-- Contenido del proyecto -->
            <div class="w-full md:w-7/12 lg:w-1/2 flex flex-col justify-center">
              
              <!-- Tag recuperado de tu diseño original -->
              <span class="font-mono text-sm text-[var(--text-muted)] mb-2 inline-block">
                {proyecto.tag}
              </span>
              
              <h3 class="text-2xl md:text-3xl font-bold mb-4 text-[var(--text-main)] tracking-tight">{proyecto.title}</h3>
              
              <!-- Chips -->
              <div class="flex flex-wrap gap-2 mb-6">
                {proyecto.chips.map(chip => (
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border border-[var(--border)] bg-[var(--surface)] text-[var(--text-main)] shadow-sm">
                    {chip}
                  </span>
                ))}
              </div>

              <p class="text-[var(--text-muted)] text-base md:text-lg mb-8 leading-relaxed">
                {proyecto.desc}
              </p>
              
              <div class="flex flex-wrap gap-3 mt-auto">
                {proyecto.github && (
                  <a href={proyecto.github} target="_blank" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-sans text-sm font-medium transition-all duration-200 border shadow-sm hover:shadow-md hover:-translate-y-0.5 active:translate-y-0 active:shadow-sm bg-[var(--surface)] text-[var(--text-main)] border-[var(--border)] hover:bg-[var(--bg)]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A4.8 4.8 0 0 0 8 18v4"></path></svg>
                    Code
                  </a>
                )}
                {proyecto.preview && (
                  <a href={proyecto.preview} target="_blank" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-sans text-sm font-medium transition-all duration-200 border shadow-sm hover:shadow-md hover:-translate-y-0.5 active:translate-y-0 active:shadow-sm bg-[var(--surface)] text-[var(--text-main)] border-[var(--border)] hover:bg-[var(--bg)]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                    Preview
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>

<!-- El observer de animación ahora es el único script que necesita quedarse en index -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const entries = document.querySelectorAll('.fade-up-entry');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((items) => {
        items.forEach(item => {
          if (item.isIntersecting) {
            item.target.classList.add('visible');
            io.unobserve(item.target);
          }
        });
      }, { threshold: 0.1 });
      entries.forEach(el => io.observe(el));
    } else {
      entries.forEach(el => el.classList.add('visible'));
    }
  });
</script>