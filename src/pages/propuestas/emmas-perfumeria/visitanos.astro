---
import Layout from "@prototipos/layouts/Layout.astro";
import Sprig from "@prototipos/components/Sprig.astro";
---

<Layout title="Visítanos" active="sucursal">
  <section class="section-tight visit-head">
    <div class="container">
      <span class="eyebrow">Plaza Y Griega</span>
      <h1>Visítanos</h1>
      <p>
        Descubre nuestra perfumería artesanal en Plaza Y Griega. Vive la calidez
        táctil del slow-living.
      </p>
    </div>
  </section>

  <section class="visit-main">
    <div class="container visit-grid">
      <div class="details-card">
        <h2>Detalles de la tienda</h2>

        <div class="detail-row">
          <span class="icon" aria-hidden="true">📍</span>
          <div>
            <p class="detail-label">Dirección</p>
            <p class="detail-value">
              Blvd. Agustín de Vildosola 335<br />
              Local 11, Plaza Y Griega<br />
              Hermosillo, Sonora
            </p>
          </div>
        </div>

        <div class="detail-row">
          <span class="icon" aria-hidden="true">🕘</span>
          <div>
            <p class="detail-label">Horario</p>
            <p class="detail-value">
              Lun – Vie: 10:00 AM – 7:00 PM<br />
              Sábado: 10:00 AM – 5:00 PM<br />
              Domingo: Cerrado
            </p>
          </div>
        </div>

        <div class="detail-row">
          <span class="icon" aria-hidden="true">✉️</span>
          <div>
            <p class="detail-label">Contacto</p>
            <p class="detail-value">hola@emmasperfumeria.mx</p>
          </div>
        </div>

        <a
          href="mailto:marcos@marcosochoa.dev?subject=Me%20interesa%20saber%20sobre%20el%20servicio%20web%20Casa%20Nostra"
          class="btn btn-whatsapp"
        >
          <span aria-hidden="true">💬</span> Escríbenos por WhatsApp
        </a>
      </div>

      <div class="visit-media">
        <Sprig bg="#eee6d8" stroke="#4a5d45" />
        <div class="map-placeholder">
          <p>Mapa · Plaza Y Griega, Hermosillo</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-tight visit-note">
    <div class="container visit-note-inner">
      <div>
        <span class="eyebrow">Antes de venir</span>
        <h2>Reserva una sesión olfativa</h2>
        <p>
          Nuestro equipo te guía a través de las familias olfativas para
          encontrar tu esencia. Escríbenos y coordinamos tu visita a Plaza Y
          Griega.
        </p>
      </div>
      <a href="/propuestas/emmas-perfumeria/catalogo" class="btn btn-secondary"
        >Ver Catálogo</a
      >
    </div>
  </section>
</Layout>

<style>
  .visit-head h1 {
    font-size: clamp(30px, 4.4vw, 44px);
    margin-top: 10px;
  }
  .visit-head p {
    margin-top: 14px;
    max-width: 520px;
    color: var(--ink-soft);
  }

  .visit-grid {
    display: grid;
    gap: 28px;
  }

  .details-card {
    background: var(--cream-alt);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px 28px;
  }
  .details-card h2 {
    font-size: 22px;
    margin-bottom: 22px;
  }
  .detail-row {
    display: flex;
    gap: 16px;
    padding: 18px 0;
    border-top: 1px solid var(--border);
  }
  .details-card h2 + .detail-row {
    border-top: none;
    padding-top: 0;
  }
  .icon {
    font-size: 18px;
    line-height: 1.4;
  }
  .detail-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin-bottom: 6px;
  }
  .detail-value {
    font-size: 15px;
    color: var(--ink);
    line-height: 1.65;
  }
  .btn-whatsapp {
    margin-top: 24px;
  }

  .visit-media {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }
  .visit-media svg {
    aspect-ratio: 4/5;
    object-fit: cover;
  }
  .map-placeholder {
    position: absolute;
    inset: auto 16px 16px;
    background: rgba(252, 249, 247, 0.92);
    border-radius: 12px;
    padding: 14px 18px;
    font-size: 13px;
    color: var(--ink-soft);
  }

  .visit-note {
    background: var(--cream-alt);
  }
  .visit-note-inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
  }
  .visit-note h2 {
    margin-top: 10px;
    font-size: clamp(22px, 2.8vw, 28px);
  }
  .visit-note p {
    margin-top: 14px;
    color: var(--ink-soft);
    max-width: 460px;
  }

  @media (min-width: 900px) {
    .visit-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
    .visit-media svg {
      aspect-ratio: 5/6;
    }
    .visit-note-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
