---
import Layout from "@prototipos/layouts/emmas-perfumeria/Layout.astro";
import BottleArt from "@prototipos/components/emmas-perfumeria/BottleArt.astro";

const products = [
  {
    name: "C-MYSLF L'Bleu",
    family: "Amaderada",
    notes: "Cedro Atlas, Vetiver, Bergamota",
    price: "$120.00",
    liquid: "#a9682f",
    cap: "#3a4a37",
    label: "C-MYSLF",
  },
  {
    name: "Sombra de Vetiver",
    family: "Amaderada",
    notes: "Vetiver, Sándalo, Pimienta",
    price: "$145.00",
    liquid: "#8a5a2c",
    cap: "#2b2822",
    label: "SOMBRA",
  },
  {
    name: "Azahar de Alba",
    family: "Cítrica",
    notes: "Bergamota, Pomelo, Hoja de Limón",
    price: "$110.00",
    liquid: "#d9a441",
    cap: "#4a5d45",
    label: "AZAHAR",
  },
  {
    name: "Jardín Nocturno",
    family: "Floral",
    notes: "Jazmín, Iris, Almizcle Blanco",
    price: "$135.00",
    liquid: "#c48a97",
    cap: "#4a5d45",
    label: "JARDÍN",
  },
  {
    name: "Esencia Salvaje",
    family: "Herbal",
    notes: "Lavanda, Salvia, Musgo de Roble",
    price: "$128.00",
    liquid: "#8fa07f",
    cap: "#3a4a37",
    label: "SALVAJE",
  },
  {
    name: "Étude Botanique No.04",
    family: "Amaderada",
    notes: "Sándalo, Bergamota, Ámbar",
    price: "$145.00",
    liquid: "#a9682f",
    cap: "#3a4a37",
    label: "ÉTUDE",
  },
];

const filters = ["Todas", "Amaderada", "Cítrica", "Floral", "Herbal"];
---

<Layout title="Catálogo" active="catalogo">
  <section class="section-tight catalog-head">
    <div class="container">
      <span class="eyebrow">Colección completa</span>
      <h1>Nuestro Catálogo</h1>
      <p>
        Descubre nuestra colección de esencias artesanales, destiladas con
        botánicos puros y presentadas en frascos de vidrio ámbar para preservar
        su integridad natural.
      </p>

      <div
        class="filters"
        role="group"
        aria-label="Filtrar por familia olfativa"
      >
        {
          filters.map((f, i) => (
            <label class="pill-wrap">
              <input
                type="radio"
                name="filter"
                checked={i === 0}
                class="visually-hidden"
              />
              <span class="pill">{f}</span>
            </label>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="product-grid">
        {
          products.map((p) => (
            <a
              href="/propuestas/emmas-perfumeria/producto"
              class="product-card"
            >
              <div class="product-media">
                <BottleArt liquid={p.liquid} cap={p.cap} label={p.label} />
                <span class="tag">{p.family}</span>
              </div>
              <div class="product-info">
                <div>
                  <h3>{p.name}</h3>
                  <p class="notes">{p.notes}</p>
                  <p class="price">{p.price}</p>
                </div>
                <span class="btn btn-primary btn-detail">Ver Detalle →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .catalog-head h1 {
    font-size: clamp(30px, 4.4vw, 44px);
    margin-top: 10px;
  }
  .catalog-head p {
    margin-top: 14px;
    max-width: 560px;
    color: var(--ink-soft);
    font-size: 16px;
  }

  .filters {
    display: flex;
    gap: 10px;
    margin-top: 28px;
    overflow-x: auto;
    padding-bottom: 4px;
  }
  .pill-wrap input:checked + .pill {
    background: var(--olive);
    border-color: var(--olive);
    color: var(--cream);
  }

  .product-grid {
    display: grid;
    gap: 28px;
  }
  .product-card {
    display: flex;
    flex-direction: column;
    border-radius: 18px;
    overflow: hidden;
    background: var(--cream);
    border: 1px solid var(--border);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 40px rgba(43, 40, 34, 0.1);
  }
  .product-media {
    position: relative;
  }
  .product-media svg {
    aspect-ratio: 4/5;
    object-fit: cover;
  }
  .tag {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--olive);
    color: var(--cream);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 999px;
  }
  .product-info {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    flex: 1;
  }
  .product-info h3 {
    font-size: 20px;
  }
  .notes {
    margin-top: 6px;
    color: var(--ink-soft);
    font-size: 14px;
  }
  .price {
    margin-top: 10px;
    font-family: var(--serif);
    font-size: 18px;
  }
  .btn-detail {
    align-self: flex-start;
    padding: 12px 22px;
    font-size: 13px;
  }

  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .product-info {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
