---
import Layout from "@prototipos/layouts/Layout.astro";
import Sprig from "@prototipos/components/Sprig.astro";
import BottleArt from "@prototipos/components/BottleArt.astro";
---

<Layout title="Inicio" active="inicio">
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-media">
        <Sprig bg="#eee6d8" stroke="#4a5d45" />
        <div class="hero-card">
          <span class="eyebrow"><span class="dot"></span>Nueva Sucursal</span>
          <h1>Plaza Y Griega</h1>
          <p>
            Blvd. Agustín de Vildosola 335, Local 11.<br />
            Te esperamos en nuestro nuevo espacio dedicado a la perfumería artesanal.
          </p>
          <div class="hero-actions">
            <a
              href="/propuestas/emmas-perfumeria/catalogo"
              class="btn btn-primary">Ver Catálogo</a
            >
            <a
              href="/propuestas/emmas-perfumeria/visitanos"
              class="btn btn-secondary">Visítanos</a
            >
          </div>
        </div>
      </div>

      <div class="hero-copy">
        <span class="eyebrow">Perfumería artesanal</span>
        <h2>Esencias destiladas de la tierra, embotelladas con paciencia.</h2>
        <p>
          En Botánica trabajamos con ingredientes botánicos puros —maderas,
          cítricos y flores— para crear fragancias que respetan el ritmo lento
          de lo hecho a mano. Cada frasco de vidrio ámbar guarda una historia
          distinta.
        </p>
        <a href="/propuestas/emmas-perfumeria/catalogo" class="link-arrow"
          >Explorar la colección →</a
        >
      </div>
    </div>
  </section>

  <!-- ESENCIAS / FAMILIAS OLFATIVAS -->
  <section class="section families">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Nuestras Esencias</span>
        <h2>Tres familias, un mismo respeto por lo natural.</h2>
        <p>
          Explora nuestras familias olfativas, creadas con ingredientes
          botánicos puros y un profundo respeto por la naturaleza que las
          origina.
        </p>
      </div>

      <div class="families-grid">
        <a href="/propuestas/emmas-perfumeria/catalogo" class="family-card">
          <Sprig bg="#f4efe8" stroke="#b08b63" />
          <div class="family-text">
            <h3>Cítrica</h3>
            <p>Bergamota, pomelo y hoja de limón. Luminosa y despierta.</p>
          </div>
        </a>
        <a href="/propuestas/emmas-perfumeria/catalogo" class="family-card">
          <Sprig bg="#e7ebe1" stroke="#4a5d45" />
          <div class="family-text">
            <h3>Amaderada</h3>
            <p>Cedro atlas, vetiver y sándalo. Cálida y envolvente.</p>
          </div>
        </a>
        <a href="/propuestas/emmas-perfumeria/catalogo" class="family-card">
          <Sprig bg="#f0e7e3" stroke="#8a6b57" />
          <div class="family-text">
            <h3>Floral</h3>
            <p>Jazmín, iris y azahar. Suave y de temperamento clásico.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- STORYTELLING: HECHO A MANO -->
  <section class="section handcraft">
    <div class="container handcraft-inner">
      <div class="handcraft-media">
        <BottleArt liquid="#a9682f" cap="#3a4a37" bg="#f4efe8" label="ÉTUDE" />
      </div>
      <div class="handcraft-copy">
        <span class="eyebrow">Nuestro proceso</span>
        <h2>Hecho a mano en cada gota.</h2>
        <p>
          Destilamos pequeños lotes en frascos de vidrio ámbar que protegen la
          integridad de cada esencia. Sin prisa, sin atajos: solo botánicos
          puros, tiempo y oficio.
        </p>
        <ul class="handcraft-list">
          <li>Ingredientes botánicos de origen verificado</li>
          <li>Destilación en lotes pequeños, sin prisas</li>
          <li>Envasado en vidrio ámbar para preservar la esencia</li>
        </ul>
        <a href="/propuestas/emmas-perfumeria/producto" class="link-arrow"
          >Conocer un frasco de cerca →</a
        >
      </div>
    </div>
  </section>

  <!-- CTA SUCURSAL -->
  <section class="section-tight visit-cta">
    <div class="container visit-cta-inner">
      <div>
        <span class="eyebrow" style="color: var(--cream-alt);"
          >Plaza Y Griega · Hermosillo</span
        >
        <h2>Vive la calidez táctil del slow-living.</h2>
      </div>
      <a
        href="/propuestas/emmas-perfumeria/visitanos"
        class="btn btn-primary"
        style="background: var(--cream); color: var(--ink);">Visítanos</a
      >
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-top: clamp(32px, 5vw, 56px);
  }
  .hero-inner {
    display: grid;
    gap: 40px;
  }
  .hero-media {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }
  .hero-media svg {
    aspect-ratio: 4/5;
    object-fit: cover;
  }
  .hero-card {
    position: relative;
    margin: -80px auto 0;
    max-width: 360px;
    background: var(--cream);
    border-radius: 16px;
    padding: 28px 26px 30px;
    box-shadow: 0 20px 50px rgba(43, 40, 34, 0.12);
  }
  .hero-card .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--olive);
    display: inline-block;
  }
  .hero-card h1 {
    font-size: clamp(32px, 5vw, 40px);
    margin-top: 14px;
  }
  .hero-card p {
    margin-top: 14px;
    color: var(--ink-soft);
    font-size: 15px;
  }
  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 24px;
  }
  .hero-actions .btn {
    width: 100%;
  }

  .hero-copy {
    padding: 4px 4px 8px;
  }
  .hero-copy h2 {
    font-size: clamp(24px, 3.2vw, 32px);
    margin-top: 12px;
  }
  .hero-copy p {
    margin-top: 16px;
    color: var(--ink-soft);
  }
  .link-arrow {
    display: inline-block;
    margin-top: 22px;
    font-family: var(--serif);
    font-size: 17px;
    color: var(--olive);
    border-bottom: 1px solid var(--olive);
    padding-bottom: 2px;
  }

  .families-grid {
    display: grid;
    gap: 20px;
  }
  .family-card {
    border-radius: 18px;
    overflow: hidden;
    background: var(--cream-alt);
    border: 1px solid var(--border);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .family-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 30px rgba(43, 40, 34, 0.08);
  }
  .family-card svg {
    aspect-ratio: 16/10;
    object-fit: cover;
  }
  .family-text {
    padding: 20px 22px 24px;
  }
  .family-text h3 {
    font-size: 22px;
  }
  .family-text p {
    margin-top: 8px;
    color: var(--ink-soft);
    font-size: 14px;
  }

  .handcraft {
    background: var(--cream-alt);
  }
  .handcraft-inner {
    display: grid;
    gap: 40px;
    align-items: center;
  }
  .handcraft-media {
    border-radius: 20px;
    overflow: hidden;
  }
  .handcraft-copy h2 {
    font-size: clamp(26px, 3.4vw, 36px);
    margin-top: 12px;
  }
  .handcraft-copy p {
    margin-top: 16px;
    color: var(--ink-soft);
  }
  .handcraft-list {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .handcraft-list li {
    padding-left: 24px;
    position: relative;
    font-size: 15px;
    color: var(--ink);
  }
  .handcraft-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 9px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--olive);
  }

  .visit-cta {
    background: var(--olive);
    color: var(--cream-alt);
  }
  .visit-cta-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: flex-start;
  }
  .visit-cta h2 {
    color: var(--cream);
    font-size: clamp(24px, 3vw, 32px);
    margin-top: 8px;
    max-width: 480px;
  }

  @media (min-width: 900px) {
    .hero-inner {
      grid-template-columns: 1.1fr 0.9fr;
      align-items: center;
    }
    .hero-media {
      order: 2;
      position: relative;
    }
    .hero-copy {
      order: 1;
    }
    .hero-card {
      margin: 0 auto;
      max-width: 360px;
      position: absolute;
      bottom: 40px;
      left: 10px;
    }
    .hero-actions {
      flex-direction: row;
    }
    .hero-actions .btn {
      width: auto;
    }

    .families-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .handcraft-inner {
      grid-template-columns: 1fr 1fr;
    }

    .visit-cta-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
