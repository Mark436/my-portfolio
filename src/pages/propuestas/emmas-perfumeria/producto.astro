---
import Layout from "@prototipos/layouts/Layout.astro";
import BottleArt from "@prototipos/components/BottleArt.astro";
import Sprig from "@prototipos/components/Sprig.astro";
---

<Layout title="Sombra de Vetiver" active="catalogo">
  <section class="section-tight">
    <div class="container breadcrumb">
      <a href="/propuestas/emmas-perfumeria/catalogo">Colecciones</a>
      <span>›</span>
      <a href="/propuestas/emmas-perfumeria/catalogo">Bosque Profundo</a>
    </div>
  </section>

  <section class="product-detail">
    <div class="container detail-grid">
      <div class="gallery">
        <div class="gallery-main">
          <BottleArt
            liquid="#8a5a2c"
            cap="#2b2822"
            bg="#efe6d8"
            label="SOMBRA"
          />
        </div>
        <div class="gallery-thumbs">
          <Sprig bg="#eee6d8" stroke="#b08b63" />
          <Sprig bg="#e7ebe1" stroke="#4a5d45" />
          <div class="thumb-play">
            <span class="play-icon">▶</span>
          </div>
        </div>
      </div>

      <div class="detail-copy">
        <span class="eyebrow">Amaderada</span>
        <h1>Sombra de Vetiver</h1>
        <p class="detail-sub">Eau de Parfum · 50ml</p>
        <p class="detail-price">$145.00</p>
        <p class="detail-desc">
          Un acorde profundo de vetiver ahumado y sándalo, templado con una nota
          de pimienta negra. Destilada en lotes pequeños y envejecida en vidrio
          ámbar para preservar su carácter terroso.
        </p>

        <div class="detail-actions">
          <a
            href="/propuestas/emmas-perfumeria/visitanos"
            class="btn btn-primary">Consultar disponibilidad</a
          >
          <a
            href="/propuestas/emmas-perfumeria/catalogo"
            class="btn btn-secondary">Ver más esencias</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- PIRÁMIDE OLFATIVA -->
  <section class="section pyramid">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">La composición</span>
        <h2>Pirámide Olfativa</h2>
        <p>
          Tres capas que se revelan con el tiempo, del primer contacto hasta el
          fondo cálido que perdura en la piel.
        </p>
      </div>

      <div class="pyramid-grid">
        <div class="pyramid-card">
          <span class="pyramid-index">Salida</span>
          <h3>Notas de Salida</h3>
          <p>
            Bergamota, pimienta rosa y hoja de vetiver fresca. Los primeros
            quince minutos.
          </p>
        </div>
        <div class="pyramid-card">
          <span class="pyramid-index">Corazón</span>
          <h3>Notas de Corazón</h3>
          <p>
            Vetiver ahumado, iris y una pizca de cedro atlas. El carácter de la
            fragancia.
          </p>
        </div>
        <div class="pyramid-card">
          <span class="pyramid-index">Fondo</span>
          <h3>Notas de Fondo</h3>
          <p>
            Sándalo, ámbar gris y musgo de roble. Lo que permanece horas
            después.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO ARTESANAL -->
  <section class="section-tight process">
    <div class="container process-inner">
      <div class="process-media">
        <Sprig bg="#f4efe8" stroke="#4a5d45" />
      </div>
      <div>
        <span class="eyebrow">El oficio</span>
        <h2>Destilada a mano, en lotes de no más de cincuenta frascos.</h2>
        <p>
          Cada esencia reposa un mínimo de seis semanas antes de ser envasada,
          permitiendo que sus notas se asienten en armonía. El resultado es una
          fragancia que evoluciona con quien la porta.
        </p>
        <a href="/propuestas/emmas-perfumeria/visitanos" class="link-arrow"
          >Conócenos en Plaza Y Griega →</a
        >
      </div>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 13px;
    color: var(--ink-soft);
  }
  .breadcrumb a {
    color: var(--ink-soft);
  }
  .breadcrumb a:hover {
    color: var(--olive);
  }

  .detail-grid {
    display: grid;
    gap: 32px;
  }
  .gallery-main {
    border-radius: 18px;
    overflow: hidden;
  }
  .gallery-main svg {
    aspect-ratio: 4/5;
    object-fit: cover;
  }
  .gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 12px;
  }
  .gallery-thumbs svg {
    border-radius: 10px;
    aspect-ratio: 1/1;
    object-fit: cover;
  }
  .thumb-play {
    border-radius: 10px;
    background: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1/1;
  }
  .play-icon {
    color: var(--cream);
    font-size: 18px;
  }

  .detail-copy h1 {
    font-size: clamp(30px, 4vw, 42px);
    margin-top: 10px;
  }
  .detail-sub {
    margin-top: 10px;
    color: var(--ink-soft);
    font-size: 15px;
  }
  .detail-price {
    margin-top: 14px;
    font-family: var(--serif);
    font-size: 26px;
    color: var(--olive);
  }
  .detail-desc {
    margin-top: 20px;
    color: var(--ink-soft);
    font-size: 16px;
    max-width: 480px;
  }
  .detail-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 28px;
  }

  .pyramid {
    background: var(--cream-alt);
  }
  .pyramid-grid {
    display: grid;
    gap: 20px;
  }
  .pyramid-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 24px;
  }
  .pyramid-index {
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--olive);
    font-weight: 600;
  }
  .pyramid-card h3 {
    margin-top: 12px;
    font-size: 21px;
  }
  .pyramid-card p {
    margin-top: 10px;
    color: var(--ink-soft);
    font-size: 15px;
  }

  .process-inner {
    display: grid;
    gap: 32px;
    align-items: center;
  }
  .process-media {
    border-radius: 18px;
    overflow: hidden;
  }
  .process h2 {
    font-size: clamp(24px, 3vw, 32px);
    margin-top: 12px;
  }
  .process p {
    margin-top: 16px;
    color: var(--ink-soft);
    max-width: 460px;
  }

  @media (min-width: 900px) {
    .detail-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
    .detail-actions {
      flex-direction: row;
    }
    .pyramid-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .process-inner {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
