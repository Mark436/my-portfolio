---
interface Props {
  bg?: string;
  stroke?: string;
}
const { bg = '#e7ebe1', stroke = '#4a5d45' } = Astro.props;
---
<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración botánica">
  <rect x="0" y="0" width="400" height="400" fill={bg} />
  <g fill="none" stroke={stroke} stroke-width="1.4" opacity="0.85">
    <path d="M200 360 C 190 260, 210 180, 200 40" />
    <path d="M200 300 C 160 280, 140 250, 120 220" />
    <path d="M200 300 C 240 280, 260 250, 280 220" />
    <path d="M200 220 C 165 205, 145 180, 130 150" />
    <path d="M200 220 C 235 205, 255 180, 270 150" />
    <path d="M200 140 C 175 120, 165 95, 160 70" />
    <path d="M200 140 C 225 120, 235 95, 240 70" />
    <ellipse cx="120" cy="220" rx="26" ry="12" transform="rotate(-30 120 220)" />
    <ellipse cx="280" cy="220" rx="26" ry="12" transform="rotate(30 280 220)" />
    <ellipse cx="130" cy="150" rx="22" ry="10" transform="rotate(-35 130 150)" />
    <ellipse cx="270" cy="150" rx="22" ry="10" transform="rotate(35 270 150)" />
    <circle cx="160" cy="70" r="10" />
    <circle cx="240" cy="70" r="10" />
  </g>
</svg>
