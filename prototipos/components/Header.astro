---
interface Props {
  active?: "inicio" | "catalogo" | "sucursal";
}
const { active } = Astro.props;
---

<header class="site-header">
  <div class="container header-inner">
    <input type="checkbox" id="nav-toggle" class="nav-toggle" />
    <label for="nav-toggle" class="hamburger" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <a href="/propuestas/emmas-perfumeria/" class="brand">EMMA'S PERFUMERIA</a>

    <nav class="nav-desktop" aria-label="Navegación principal">
      <a
        href="/propuestas/emmas-perfumeria/"
        class={active === "inicio" ? "is-active" : ""}>Inicio</a
      >
      <a
        href="/propuestas/emmas-perfumeria/catalogo"
        class={active === "catalogo" ? "is-active" : ""}>Catálogo</a
      >
      <a
        href="/propuestas/emmas-perfumeria/visitanos"
        class={active === "sucursal" ? "is-active" : ""}>Sucursal</a
      >
    </nav>

    <a
      href="/propuestas/emmas-perfumeria/visitanos"
      class="btn btn-secondary header-cta">Visítanos</a
    >

    <label for="nav-toggle" class="nav-scrim"></label>
    <nav class="nav-mobile" aria-label="Navegación móvil">
      <a href="/propuestas/emmas-perfumeria/">Inicio</a>
      <a href="/propuestas/emmas-perfumeria/catalogo">Catálogo</a>
      <a href="/propuestas/emmas-perfumeria/producto">Producto</a>
      <a href="/propuestas/emmas-perfumeria/visitanos">Sucursal</a>
      <a
        href="/propuestas/emmas-perfumeria/visitanos"
        class="btn btn-primary nav-mobile-cta">Visítanos</a
      >
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(252, 249, 247, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: grid;
    grid-template-columns: 40px 1fr 40px;
    align-items: center;
    height: 76px;
  }
  .brand {
    grid-column: 2;
    justify-self: center;
    font-family: var(--serif);
    font-size: 20px;
    letter-spacing: 0.16em;
    color: var(--ink);
  }
  .hamburger {
    grid-column: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 24px;
    cursor: pointer;
  }
  .hamburger span {
    display: block;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
  }
  .nav-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .nav-desktop {
    display: none;
  }
  .header-cta {
    display: none;
  }

  .nav-scrim {
    position: fixed;
    inset: 0;
    background: rgba(43, 40, 34, 0.35);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .nav-mobile {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: min(78vw, 320px);
    background: var(--cream);
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 96px 32px 40px;
    transform: translateX(-100%);
    transition: transform 0.35s ease;
    box-shadow: 20px 0 40px rgba(43, 40, 34, 0.06);
  }
  .nav-mobile a {
    font-family: var(--serif);
    font-size: 22px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    color: var(--ink);
  }
  .nav-mobile-cta {
    margin-top: 24px;
    border: none;
  }

  .nav-toggle:checked ~ .nav-scrim {
    opacity: 1;
    pointer-events: auto;
  }
  .nav-toggle:checked ~ .nav-mobile {
    transform: translateX(0);
  }

  @media (min-width: 900px) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
      gap: 40px;
    }
    .brand {
      grid-column: 1;
      justify-self: start;
      font-size: 22px;
    }
    .hamburger {
      display: none;
    }
    .nav-desktop {
      grid-column: 2;
      display: flex;
      justify-content: center;
      gap: 48px;
      font-size: 15px;
      font-weight: 500;
      color: var(--ink-soft);
    }
    .nav-desktop a {
      position: relative;
      padding: 6px 0;
      transition: color 0.2s ease;
    }
    .nav-desktop a:hover,
    .nav-desktop a.is-active {
      color: var(--olive);
    }
    .nav-desktop a.is-active::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: -2px;
      height: 1px;
      background: var(--olive);
    }
    .header-cta {
      grid-column: 3;
      display: inline-flex;
      padding: 12px 24px;
      font-size: 14px;
    }
    .nav-mobile,
    .nav-scrim {
      display: none;
    }
  }
</style>
