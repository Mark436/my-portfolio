---

<section id="ubicacion" class="bg-cantera px-5 py-20 sm:px-8 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="arch-frame arch h-64 w-full bg-adobe sm:h-80">
      <div
        class="flex h-full w-full items-center justify-center bg-gradient-to-b from-adobe to-barro"
      >
        <span
          class="font-body text-xs uppercase tracking-widest text-cantera/70"
          >Mapa · ubicación</span
        >
      </div>
    </div>
    <p class="mt-4 font-body text-sm text-hierro/70">
      Calle Guadalupe Victoria 14, Centro Histórico, Álamos, Sonora
    </p>
  </div>
</section>

<section
  id="contacto"
  class="bg-barro px-5 py-20 text-cantera sm:px-8 sm:py-28"
>
  <div class="mx-auto max-w-2xl text-center">
    <p
      class="mb-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-buganvilia"
    >
      Reserva tu fecha
    </p>
    <h2
      class="font-display text-balance text-3xl leading-tight sm:text-4xl md:text-5xl"
    >
      Cuéntanos qué estás celebrando
    </h2>
    <p class="mt-4 font-body text-base text-cantera/80 sm:text-lg">
      Respondemos disponibilidad de fecha en menos de 24 horas.
    </p>

    <form class="mt-10 flex flex-col gap-4 text-left">
      <div>
        <label
          for="nombre"
          class="mb-1.5 block font-body text-xs font-semibold uppercase tracking-wide text-cantera/70"
        >
          Nombre
        </label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          required
          class="w-full rounded-lg border border-cantera/20 bg-cantera/5 px-4 py-3 font-body text-cantera placeholder:text-cantera/40 focus:border-buganvilia focus:outline-none"
          placeholder="Tu nombre"
        />
      </div>
      <div>
        <label
          for="fecha"
          class="mb-1.5 block font-body text-xs font-semibold uppercase tracking-wide text-cantera/70"
        >
          Fecha del evento
        </label>
        <input
          type="date"
          id="fecha"
          name="fecha"
          class="w-full rounded-lg border border-cantera/20 bg-cantera/5 px-4 py-3 font-body text-cantera focus:border-buganvilia focus:outline-none"
        />
      </div>
      <div>
        <label
          for="mensaje"
          class="mb-1.5 block font-body text-xs font-semibold uppercase tracking-wide text-cantera/70"
        >
          Cuéntanos sobre tu evento
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="4"
          class="w-full rounded-lg border border-cantera/20 bg-cantera/5 px-4 py-3 font-body text-cantera placeholder:text-cantera/40 focus:border-buganvilia focus:outline-none"
          placeholder="Número de invitados, tipo de evento..."></textarea>
      </div>
      <button
        type="submit"
        class="mt-2 rounded-xl bg-buganvilia px-7 py-3.5 text-sm font-semibold uppercase tracking-wider text-cantera transition-colors hover:bg-buganvilia-dark"
      >
        Enviar solicitud
      </button>
    </form>

    <div class="mt-10 flex flex-col gap-1 font-body text-sm text-cantera/70">
      <a href="mailto:hola@lacasona.com" class="hover:text-cantera"
        >hola@lacasona.com</a
      >
      <a href="tel:+526471234567" class="hover:text-cantera">+52 647 123 4567</a
      >
    </div>
  </div>
</section>

<footer class="bg-hierro px-5 py-8 text-center sm:px-8">
  <p class="font-body text-xs uppercase tracking-widest text-cantera/50">
    La Casona · Álamos, Sonora · desde 1789
  </p>
</footer>
