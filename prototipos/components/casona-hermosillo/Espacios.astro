---
const espacios = [
  {
    nombre: "Patio del Naranjo",
    capacidad: "Hasta 180 personas",
    detalle: "Ceremonias al aire libre bajo el naranjo centenario.",
  },
  {
    nombre: "Salón de Cantera",
    capacidad: "Hasta 120 personas",
    detalle: "Techos de viga vista, ideal para recepción y baile.",
  },
  {
    nombre: "Terraza Alta",
    capacidad: "Hasta 60 personas",
    detalle: "Vista a la sierra, perfecta para cócteles al atardecer.",
  },
  {
    nombre: "Capilla del Carmen",
    capacidad: "Hasta 90 personas",
    detalle: "Espacio íntimo para ceremonias religiosas.",
  },
];
---

<section id="espacios" class="bg-cantera-soft px-5 py-20 sm:px-8 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <p
      class="mb-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-buganvilia"
    >
      Los espacios
    </p>
    <h2
      class="font-display text-balance text-3xl leading-tight text-hierro sm:text-4xl md:text-5xl"
    >
      Cuatro escenarios, una sola casona
    </h2>

    <!-- Mobile: scroll horizontal con snap · Desktop: grid -->
    <div
      class="mt-10 flex snap-x snap-mandatory gap-5 overflow-x-auto pb-4 md:grid md:grid-cols-2 md:gap-8 md:overflow-visible"
    >
      {
        espacios.map((espacio) => (
          <article class="w-[78%] flex-none snap-start md:w-auto">
            <div class="arch-frame arch h-56 w-full bg-adobe sm:h-64">
              <div class="flex h-full w-full items-center justify-center bg-gradient-to-b from-adobe to-barro">
                <span class="font-body text-xs uppercase tracking-widest text-cantera/70">
                  Fotografía
                </span>
              </div>
            </div>
            <h3 class="mt-4 font-display text-xl text-hierro">
              {espacio.nombre}
            </h3>
            <p class="mt-1 font-body text-sm font-semibold uppercase tracking-wide text-buganvilia">
              {espacio.capacidad}
            </p>
            <p class="mt-2 font-body text-sm text-hierro/75">
              {espacio.detalle}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
