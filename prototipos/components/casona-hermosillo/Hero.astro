<section
  class="relative flex min-h-svh items-end overflow-hidden bg-adobe-dark sm:items-center"
>
  <div
    class="relative z-10 mx-auto w-full max-w-6xl px-5 pb-16 pt-40 sm:px-8 sm:pb-24 sm:pt-32"
  >
    <p
      class="mb-4 font-body text-xs font-semibold uppercase tracking-[0.3em] text-cantera/80 sm:text-sm"
    >
      Álamos, Sonora
    </p>
    <h1
      class="font-display text-balance text-4xl leading-[1.05] text-cantera sm:text-6xl md:text-7xl"
    >
      Tu celebración,
      <br />
      bajo cantera y buganvilia
    </h1>
    <p class="mt-6 max-w-md font-body text-base text-cantera/85 sm:text-lg">
      Un patio colonial de 1789 restaurado para bodas, posadas y reuniones que
      merecen algo con historia.
    </p>

    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
      <a
        href="#contacto"
        class="rounded-xl bg-buganvilia px-7 py-3.5 text-center text-sm font-semibold uppercase tracking-wider text-cantera transition-colors hover:bg-buganvilia-dark"
      >
        Solicitar disponibilidad
      </a>
      <a
        href="#historia"
        class="flex items-center justify-center gap-2 px-2 py-3.5 text-sm font-semibold uppercase tracking-wider text-cantera/90 transition-colors hover:text-cantera"
      >
        Conoce La Casona
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
