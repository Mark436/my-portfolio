---
interface Props {
  liquid?: string;
  cap?: string;
  bg?: string;
  label?: string;
}
const {
  liquid = "#a9682f",
  cap = "#3a4a37",
  bg = "#f4efe8",
  label = "EMMA'S PERFUMERIA",
} = Astro.props;
---

<svg
  viewBox="0 0 400 480"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={`Frasco de perfume ${label}`}
>
  <rect x="0" y="0" width="400" height="480" fill={bg}></rect>
  <g opacity="0.5" stroke="#4a5d45" stroke-width="1">
    <path d="M40 40 C 70 60, 60 100, 90 110" fill="none"></path>
    <path d="M360 420 C 330 400, 340 360, 310 350" fill="none"></path>
  </g>
  <rect
    x="130"
    y="150"
    width="140"
    height="230"
    rx="10"
    fill={liquid}
    opacity="0.16"></rect>
  <rect
    x="130"
    y="150"
    width="140"
    height="230"
    rx="10"
    fill="none"
    stroke="#2b2822"
    stroke-width="2"></rect>
  <rect
    x="150"
    y="180"
    width="100"
    height="150"
    rx="2"
    fill={liquid}
    opacity="0.55"></rect>
  <rect
    x="150"
    y="180"
    width="100"
    height="150"
    rx="2"
    fill="none"
    stroke="#2b2822"
    stroke-width="1.2"></rect>
  <rect
    x="165"
    y="90"
    width="70"
    height="60"
    fill="none"
    stroke="#2b2822"
    stroke-width="2"></rect>
  <rect x="150" y="60" width="100" height="34" rx="6" fill={cap}></rect>
  <rect x="180" y="40" width="40" height="24" rx="3" fill={cap}></rect>
  <rect
    x="150"
    y="230"
    width="100"
    height="46"
    fill="#fcf9f7"
    stroke="#2b2822"
    stroke-width="1"></rect>
  <text
    x="200"
    y="250"
    text-anchor="middle"
    font-family="EB Garamond, serif"
    font-size="12"
    letter-spacing="2"
    fill="#2b2822">{label}</text
  >
  <text
    x="200"
    y="266"
    text-anchor="middle"
    font-family="Inter, sans-serif"
    font-size="8"
    letter-spacing="1"
    fill="#6b6357">EAU DE PARFUM</text
  >
</svg>
